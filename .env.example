# Copy to .env (gitignored) and fill in real values.
# Expo treats EXPO_PUBLIC_* as build-time public env vars baked into the JS bundle.

# PostHog (product analytics) — works in Expo Go.
EXPO_PUBLIC_POSTHOG_API_KEY=phc_xxx_replace_me
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Sentry (crash + perf) — requires dev build / EAS Build (NOT Expo Go).
EXPO_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX

# Environment tag (development | staging | production)
EXPO_PUBLIC_ENV=development
