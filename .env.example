# Copy to .env (gitignored) and fill in real values.
# Expo treats EXPO_PUBLIC_* as build-time public env vars baked into the JS bundle.

# PostHog (product analytics) — works in Expo Go.
EXPO_PUBLIC_POSTHOG_API_KEY=phc_xxx_replace_me
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Sentry (crash + perf) — requires dev build / EAS Build (NOT Expo Go).
EXPO_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX

# Environment tag (development | staging | production)
EXPO_PUBLIC_ENV=development

# Backend API. Use LAN IP for a physical device, for example http://192.168.1.20:3333
EXPO_PUBLIC_API_URL=http://localhost:3333

# EAS project id, required for Expo push tokens in standalone/dev builds.
EXPO_PUBLIC_EAS_PROJECT_ID=replace_me

# AdMob. Leave disabled until real app/ad unit IDs are created.
EXPO_PUBLIC_ADS_ENABLED=false
EXPO_PUBLIC_ADS_TEST_MODE=true
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=replace_me
EXPO_PUBLIC_ADMOB_IOS_APP_ID=replace_me
EXPO_PUBLIC_ADMOB_ANDROID_REWARDED_HINT=replace_me
EXPO_PUBLIC_ADMOB_ANDROID_REWARDED_CONTINUE=replace_me
EXPO_PUBLIC_ADMOB_IOS_REWARDED_HINT=replace_me
EXPO_PUBLIC_ADMOB_IOS_REWARDED_CONTINUE=replace_me

# RevenueCat. Leave empty until products/entitlements exist.
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=replace_me
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=replace_me
